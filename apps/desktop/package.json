{
  "name": "@cairn/desktop",
  "version": "0.1.0",
  "description": "Cairn desktop alpha: Electron + React + TypeScript shell around the local Mneme engine.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "out/main/main.js",
  "scripts": {
    "prepare:engine": "npm --prefix ../../packages/engine run build",
    "predev": "npm run prepare:engine",
    "dev": "electron-vite dev",
    "pretypecheck": "npm run prepare:engine",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && electron-vite build",
    "test": "npm run prepare:engine && tsc -p tsconfig.test.json && node --test test/vault-session.test.mjs",
    "prepreview": "npm run prepare:engine",
    "preview": "electron-vite preview",
    "prepackage": "npm run prepare:engine && electron-vite build && node scripts/rebuild-engine-native.mjs electron",
    "package": "electron-builder --dir",
    "postpackage": "node scripts/rebuild-engine-native.mjs node",
    "prepackage:dist": "npm run prepare:engine && electron-vite build && node scripts/rebuild-engine-native.mjs electron",
    "package:dist": "electron-builder --mac dmg zip",
    "postpackage:dist": "node scripts/rebuild-engine-native.mjs node"
  },
  "dependencies": {
    "@cairn/engine": "file:../../packages/engine",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.545.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.5"
  }
}
